# Development Dockerfile with hot reload support
FROM node:22-slim

WORKDIR /app

# Install dependencies into the image so the anonymous volume
# in docker-compose gets pre-seeded with Linux bindings on first run
COPY package.json ./
RUN npm install

# Copy source code
COPY . .

# Use .env.example as fallback if .env does not exist
RUN [ ! -f .env ] && cp .env.example .env || true

EXPOSE 5173

CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
